# ---------------------------------------------------------------------------
# Backend environment configuration
# Copy this file to ".env" and adjust the values for your environment.
# ---------------------------------------------------------------------------

# Database connection string.
# PostgreSQL (production / docker-compose):
#   postgresql+psycopg2://jobuser:jobpass@localhost:5432/jobaggregator
# SQLite fallback (local dev, zero setup) -> leave empty or use the line below:
#   sqlite:///./job_aggregator.db
DATABASE_URL=sqlite:///./job_aggregator.db

# Background scrape cadence. SCRAPER_INTERVAL_MINUTES wins when > 0 (default 30);
# otherwise SCRAPER_INTERVAL_HOURS is used.
SCRAPER_INTERVAL_MINUTES=30
SCRAPER_INTERVAL_HOURS=4

# ---------------------------------------------------------------------------
# Performance: async scraping + read-endpoint cache.
# ---------------------------------------------------------------------------
# Fetch all sources concurrently (asyncio.gather) instead of one at a time.
ENABLE_ASYNC_SCRAPING=true
# Max sources fetched in parallel (keep modest to stay a polite client).
SCRAPER_MAX_CONCURRENCY=8
# In-process TTL cache for /api/jobs, /api/jobs/today, /api/stats. Invalidated
# automatically after every scrape so new jobs appear immediately.
CACHE_ENABLED=true
CACHE_TTL_SECONDS=120

# Comma-separated list of keywords to track (expanded for max ServiceNow coverage).
DEFAULT_KEYWORDS=ServiceNow,ServiceNow Developer,ServiceNow Administrator,ServiceNow Consultant,ServiceNow Architect,ServiceNow Engineer,ServiceNow Platform Engineer,ServiceNow ITSM,ServiceNow CMDB,ServiceNow HRSD,ServiceNow CSM,ServiceNow Discovery,ServiceNow SecOps,ServiceNow Business Analyst,ServiceNow Integration Specialist,ServiceNow Technical Consultant,ServiceNow Solution Consultant,ServiceNow Implementation Specialist,ServiceNow Workflow,ServiceNow Platform Owner,ServiceNow App Engine

# Timezone used to determine "Posted Today". IANA name.
APP_TIMEZONE=America/New_York

# Set to "true" to start the in-process APScheduler when the API boots.
ENABLE_SCHEDULER=true

# ---------------------------------------------------------------------------
# TODAY-only mode. The portal shows ONLY jobs posted today (in APP_TIMEZONE).
# ---------------------------------------------------------------------------
# Date window. TODAY_ONLY=true => strictly today. For real, recent jobs set
# TODAY_ONLY=false and LOOKBACK_DAYS=N (jobs from the last N days). Default: 10.
TODAY_ONLY=false
LOOKBACK_DAYS=10
SCRAPER_LOOKBACK_DAYS=10
MIN_TARGET_TODAY_JOBS=50
ALLOW_UNKNOWN_DATE=false
ALLOW_YESTERDAY=true
ALLOW_LAST_3_DAYS=true
ALLOW_OLD_JOBS=false
# Max pages fetched per source per keyword (pagination depth).
MAX_PAGES_PER_SOURCE=2

# ---------------------------------------------------------------------------
# Target volume + smart query expansion. The scraper searches the whole
# ServiceNow ecosystem (roles, modules, technical terms, US phrasings) by
# generating many queries from backend/app/scraper/servicenow_taxonomy.py.
# ---------------------------------------------------------------------------
MIN_TARGET_JOBS=50
MAX_TARGET_JOBS=100
MAX_QUERIES_PER_SOURCE=5
ENABLE_QUERY_EXPANSION=true
ENABLE_STACK_SEARCH=true
ENABLE_MODULE_SEARCH=true
ENABLE_ROLE_SEARCH=true
ENABLE_TECHNICAL_TERM_SEARCH=true

# ---------------------------------------------------------------------------
# Multi-stack job mode. JOB_MODE=multi_stack searches all enabled categories
# (PHP/Laravel, Node.js, React, MERN/MEAN, Full Stack, Software Engineer,
# Python, DevOps, Data/AI, QA, ServiceNow). JOB_MODE=servicenow = legacy mode.
# Categories + keywords live in backend/app/scraper/job_taxonomy.py.
# ---------------------------------------------------------------------------
JOB_MODE=multi_stack
ENABLED_JOB_CATEGORIES=servicenow,mern,mean,node_backend,php,laravel,react_frontend
# Minimum relevance score to accept a job (higher = stricter, fewer false positives).
MIN_RELEVANCE_SCORE=70
# ServiceNow stays high-precision: generic ITSM/CMDB/GRC never counts as ServiceNow.
SERVICENOW_STRICT_MODE=true

# ---------------------------------------------------------------------------
# Strict relevance filtering — the project targets ONLY remote, US-based,
# ServiceNow jobs. A job must pass all three checks before being saved/shown.
# ---------------------------------------------------------------------------

# A job MUST contain this term (after normalization, "Service Now" == "servicenow").
REQUIRED_MATCH_TERM=servicenow
# Require the term in the ROLE signal (title/tags/category), not an incidental
# description mention (e.g. ServiceNow named as a past client). true = accurate.
SERVICENOW_REQUIRE_IN_TITLE=true

# Only keep clearly-remote jobs.
REMOTE_ONLY=true

# Target country. "US" enables US-only matching. Set to "" or "ANY" to disable.
TARGET_COUNTRY=US

# Location strings accepted as a US match (comma separated).
TARGET_LOCATIONS=United States,USA,US,U.S.,Remote US,Remote United States

# Accept Canadian remote roles alongside US (audience is US/Canada). Set false
# for strict US-only.
ALLOW_US_OR_CANADA=true

# Development-only mock data. MUST stay false in production.
ENABLE_MOCK_DATA=false

# ---------------------------------------------------------------------------
# Source toggles
# Note: Built In and Hiring Cafe are currently BLOCKED for compliance reasons
# (robots.txt / 403 / no public API). These flags are honored only if/when a
# source becomes compliant; today they remain skipped regardless. See
# SOURCES_REPORT.md.
# ---------------------------------------------------------------------------
ENABLE_REMOTEOK=true
ENABLE_REMOTIVE=true
ENABLE_ARBEITNOW=true
ENABLE_HIMALAYAS=true
ENABLE_BUILTIN=true
ENABLE_HIRING_CAFE=true
ENABLE_COMPANY_ATS=true
ENABLE_JOBRIGHT=false
ENABLE_INDEED=false
ENABLE_SIMPLYHIRED=false
ENABLE_GLASSDOOR=false
ENABLE_ZIPRECRUITER=false

# ---------------------------------------------------------------------------
# New job board source toggles
# ---------------------------------------------------------------------------
ENABLE_JOBSPRESSO=true
ENABLE_VIRTUAL_VOCATIONS=false
ENABLE_STACKOVERFLOW_JOBS=false
ENABLE_OUTSOURCELY=true
ENABLE_TOPTAL=false
ENABLE_SKIPTHEDRIVE=true
ENABLE_NODESK=true
ENABLE_REMOTEHABITS=false
ENABLE_REMOTIVE=true
ENABLE_REMOTE4ME=true
ENABLE_PANGIAN=true
ENABLE_REMOTEES=true
ENABLE_EUROPE_REMOTELY=true
ENABLE_REMOTEOK_EUROPE=true
ENABLE_REMOTE_OF_ASIA=false
ENABLE_FLEXJOBS=false
ENABLE_REMOTE_CO=true
ENABLE_WEWORKREMOTELY=true
ENABLE_WELLFOUND=false
ENABLE_LINKEDIN=false
ENABLE_UPWORK=false
ENABLE_FREELANCER=false
ENABLE_WORKING_NOMADS=true
ENABLE_REMOTE_FREELANCE=true
ENABLE_REMOTE_ROCKETSHIP=false
ENABLE_WAW_ASIA=true
ENABLE_HUBSTAFF_TALENT=true
ENABLE_COMPANY_CAREERS=true

# ---------------------------------------------------------------------------
# Key-gated API sources (OFF by default). Set ENABLE_* = true AND provide the
# key(s) to activate. Without keys they report "needs_api_key" in diagnostics.
# ---------------------------------------------------------------------------
ENABLE_ADZUNA=false
ENABLE_USAJOBS=false
ENABLE_THE_MUSE=false
ENABLE_JOOBLE=false
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
USAJOBS_EMAIL=
USAJOBS_API_KEY=
THE_MUSE_API_KEY=
JOOBLE_API_KEY=

# Diagnostics / filter tuning.
# Show ServiceNow near-matches (failed remote/US) in diagnostics only -- never saved.
DEBUG_SHOW_NEAR_MATCHES=true
# Treat worldwide/anywhere remote ServiceNow jobs as US-eligible only when no
# non-US-only country is named. Keep false for strict US-only.
ALLOW_REMOTE_WORLDWIDE_IF_US_NOT_EXCLUDED=false
# Accept jobs EXPLICITLY advertised as worldwide/global remote ("Worldwide",
# "Work From Anywhere", "Global Remote", "Remote Anywhere"). A worldwide role
# includes US candidates, so it passes the location gate. Set false for strict
# US-only.
ACCEPT_WORLDWIDE_REMOTE=true

# ---------------------------------------------------------------------------
# Company ATS public job boards (NO API key required).
# Comma-separated lists of board/company tokens. Leave empty to disable a
# platform. These are the cleanest source of genuine ServiceNow roles -- add
# ServiceNow partner/consulting firms that use each ATS.
#   Greenhouse board token -> boards.greenhouse.io/<token>
#   Lever company token    -> jobs.lever.co/<token>
#   Ashby board token      -> jobs.ashbyhq.com/<token>
# ---------------------------------------------------------------------------
# Confirmed-live ServiceNow partner/consulting boards (probed 2026-06-29).
# These hold real ServiceNow remote roles; add more partner tokens to widen.
#
# ServiceNow partner/consulting firms worth investigating (verify which ATS each
# one actually uses -- not every company uses Greenhouse/Lever/Ashby; if a board
# token 404s it is logged in diagnostics and otherwise ignored):
#   newrocket, thirdera, cprime, crossfuze, glidefast, servicenow, accenture,
#   deloitte, cognizant, infosys, capgemini, dxc, nttdata, kpmg, pwc, ey, wipro,
#   hcltech, epam, cdw, guidehouse, leidos, saic, boozallen, bounteous,
#   netimpact, acorio
GREENHOUSE_BOARDS=highmetric
LEVER_COMPANIES=cprime
ASHBY_BOARDS=rapdev

# ---------------------------------------------------------------------------
# Company career discovery (multi-ATS auto-discovery by company name).
# The CompanyCareers source tries Greenhouse/Lever/Ashby for each company.
# ---------------------------------------------------------------------------
COMPANY_CAREER_TARGETS=Samsara,1Password,Grafana Labs,Humana,MongoDB,Wiz,Oscilar,Circle,Palo Alto Networks,Veeam Software,Lumenalta,Ruby Labs,Caylent,Yuno,micro1,Hostinger,Kraken,Scopely,LaunchDarkly,Fleetio,Trafilea,Absorb Software,GoGuardian,Polygon Labs,Workweek,Automattic,Deel

# Additional ATS board lists (comma-separated company/board tokens).
WORKDAY_COMPANIES=
SMARTRECRUITERS_COMPANIES=
RECRUITEE_COMPANIES=
TEAMTAILOR_COMPANIES=
COMEET_COMPANIES=

# Comma-separated list of allowed CORS origins for the frontend.
# The backend also hardcodes localhost + Vercel production + a regex for Vercel
# preview deploys, so this is for any ADDITIONAL origins you want to allow.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://techlabz-scraper.vercel.app

# Polite scraping: seconds to wait between HTTP requests to a single source.
REQUEST_DELAY_SECONDS=1.5

# HTTP request timeout in seconds.
REQUEST_TIMEOUT_SECONDS=20

# ---------------------------------------------------------------------------
# DEPLOYMENT NOTES
# ---------------------------------------------------------------------------
#
# Render backend env vars (set in Render dashboard):
#   DATABASE_URL=postgresql+psycopg2://...
#   APP_TIMEZONE=America/New_York
#   LOOKBACK_DAYS=10
#   JOB_MODE=multi_stack
#   REMOTE_ONLY=true
#   TARGET_COUNTRY=US
#   TARGET_LOCATIONS=United States,USA,US,U.S.,Remote US,Remote United States
#   ALLOW_UNKNOWN_DATE=false
#   ALLOW_OLD_JOBS=false
#   ENABLE_SCHEDULER=true
#   SCRAPER_INTERVAL_HOURS=4
#   PYTHON_VERSION=3.11.9
#   CORS_ORIGINS=https://techlabz-scraper.vercel.app
#
# Vercel frontend env vars (set in Vercel dashboard):
#   VITE_API_BASE_URL=https://techlabz-scraper.onrender.com

